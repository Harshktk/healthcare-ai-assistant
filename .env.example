# =====================================================================
# Healthcare AI Assistant — environment configuration
# Copy this file to .env and adjust for your local setup.
# =====================================================================

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# --- Data + storage paths ---
# Folder containing healthcare documents to ingest.
DATA_DIR=./data
# ChromaDB persistent storage location.
VECTOR_STORE_DIR=./vector_store
# Chroma collection name.
COLLECTION_NAME=healthcare_docs

# --- Embeddings ---
# Any sentence-transformers model name will work.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Chunking ---
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# --- Retrieval ---
TOP_K=4
# Cosine-distance thresholds for confidence labelling.
# Chroma returns *distance* (lower = more similar). For all-MiniLM-L6-v2
# normalised embeddings, distance ~= 1 - cosine similarity.
CONFIDENCE_HIGH_MAX_DISTANCE=0.4
CONFIDENCE_MEDIUM_MAX_DISTANCE=0.6

# --- LLM (Ollama) ---
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=llama3.2:3b
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=60

# --- UI ---
UI_PORT=8501
# URL the Streamlit UI uses to reach the API. Use http://api:8000 inside Docker.
API_BASE_URL=http://localhost:8000
