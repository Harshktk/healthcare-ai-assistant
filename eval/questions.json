{
  "description": "Curated evaluation set for the Healthcare AI Assistant. Each question is tagged with the expected intent, expected source document(s), and either keywords that must appear in the answer or a flag for the refusal sentinel.",
  "questions": [
    {
      "id": "kb-001",
      "question": "Can a patient request a medication refill through telehealth?",
      "expected_intent": "knowledge",
      "expected_documents": ["telehealth_policy.md", "medication_refill_policy.md"],
      "must_include_any": ["telehealth", "refill"],
      "must_not_be_refusal": true
    },
    {
      "id": "kb-002",
      "question": "Are controlled substances eligible for telehealth refill?",
      "expected_intent": "knowledge",
      "expected_documents": ["telehealth_policy.md", "medication_refill_policy.md"],
      "must_include_any": ["cannot", "in person", "in-person"],
      "must_not_be_refusal": true
    },
    {
      "id": "kb-003",
      "question": "What is the cancellation policy if I cancel two hours before my appointment?",
      "expected_intent": "knowledge",
      "expected_documents": ["appointment_scheduling_policy.md"],
      "must_include_any": ["fee", "fifty", "late"],
      "must_not_be_refusal": true
    },
    {
      "id": "kb-004",
      "question": "Do I need a referral to see a specialist?",
      "expected_intent": "knowledge",
      "expected_documents": ["insurance_eligibility_faq.md"],
